    "monaco-editor": "^0.55.1",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "pretty-bytes": "^7.1.0",
    "sortablejs": "^1.15.7",
    "ulidx": "^2.4.1",
    "vee-validate": "^4.15.1",
    "virtua": "^0.49.1",
    "vue": "^3.5.26",
    "vue-i18n": "^11.2.8",
    "vue-router": "^4.6.4",
    "zod": "^3.25.76"
