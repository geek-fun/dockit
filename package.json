{
  "name": "dockit",
  "private": true,
  "type": "module",
  "version": "1.3.0",
  "description": "Agentic desktop GUI client for Elasticsearch, OpenSearch, DynamoDB, MongoDB and EasySearch. Query with natural language. Available for Mac, Windows and Linux.",
  "keywords": [
    "elasticsearch",
    "opensearch",
    "dynamodb",
    "mongodb",
    "easysearch",
    "nosql",
    "kibana",
    "copilot",
    "database-gui",
    "database-manager",
    "elasticsearch-client",
    "elasticsearch-gui",
    "dynamodb-gui-client",
    "dynamodb-local",
    "opensearch-dashboards",
    "ai-agent",
    "natural-language-query",
    "tauri",
    "tauri-app",
    "desktop-app"
  ],
  "author": "geekfun <support@geekfun.club>",
  "homepage": "https://www.geekfun.club/products/dockit/",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/geek-fun/dockit.git"
  },
  "bugs": {
    "url": "https://github.com/geek-fun/dockit/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint:fix": "eslint --fix ./",
    "lint:check": "eslint ./",
    "test": "jest --runInBand --coverage --coverageReporters json-summary text html lcov && cargo test --manifest-path src-tauri/Cargo.toml",
    "test:ci": "npx jest --runInBand --ci --coverage --coverageReporters json-summary text html lcov",
    "build:macos": "tauri build -t universal-apple-darwin"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.0",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
